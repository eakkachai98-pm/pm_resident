// This is your Prisma schema file for Resident soft (Dormitory Management)

generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String   @id @default(cuid())
  role        String   @default("RESIDENT") // 'ADMIN', 'STAFF', 'RESIDENT'
  name        String
  email       String   @unique
  phone       String?
  password    String   @default("password123")
  createdAt   DateTime @default(now())

  // Additional Info for Tenant Management
  nationality       String   @default("Thai") // 'Thai' or 'Foreigner'
  identityNumber    String?  // ID Card or Passport Number
  preferredLanguage String   @default("th") // 'th', 'en', 'zh'
  emergencyContact  String?
  visaExpiryDate    DateTime?
  tm30Reported      Boolean  @default(false)

  // Relations
  leases              Lease[]
  maintenanceTickets  MaintenanceTicket[] @relation("Reporter")
  assignedTickets     MaintenanceTicket[] @relation("Assignee")
  technicianAvailability TechnicianAvailability?
  technicianBlockedSlots TechnicianBlockedSlot[]
  documents           TenantDocument[]
}

model Room {
  id          String   @id @default(cuid())
  roomNumber  String   @unique
  floor       Int
  roomType    String   @default("Standard") // 'Standard', 'Commercial'
  price       Float
  status      String   @default("AVAILABLE") // 'AVAILABLE', 'OCCUPIED', 'MAINTENANCE'

  // Relations
  leases             Lease[]
  meterReadings      MeterReading[]
  maintenanceTickets MaintenanceTicket[]
}

model Lease {
  id             String   @id @default(cuid())
  startDate      DateTime @default(now())
  endDate        DateTime?
  isActive       Boolean  @default(true)

  // Relations
  roomId         String
  room           Room     @relation(fields: [roomId], references: [id])
  tenantId       String
  tenant         User     @relation(fields: [tenantId], references: [id])
  invoices       Invoice[]
}

model MeterReading {
  id             String   @id @default(cuid())
  billingMonth   String   // e.g. "2024-10"
  waterMeter     Float
  electricMeter  Float
  createdAt      DateTime @default(now())

  // Relations
  roomId         String
  room           Room     @relation(fields: [roomId], references: [id])
}

model Invoice {
  id             String   @id @default(cuid())
  billingMonth   String
  roomRent       Float
  waterCharge    Float
  electricCharge Float
  totalAmount    Float
  status         String   @default("UNPAID") // 'UNPAID', 'PENDING_VERIFICATION', 'PAID'
  slipImageUrl   String?
  createdAt      DateTime @default(now())

  // Relations
  leaseId        String
  lease          Lease    @relation(fields: [leaseId], references: [id])
}

model MaintenanceTicket {
  id             String   @id @default(cuid())
  title          String
  description    String?
  category       String   @default("General") // 'Water', 'Electric', 'AirCon', 'General'
  status         String   @default("OPEN") // 'OPEN', 'IN_PROGRESS', 'RESOLVED'
  createdAt      DateTime @default(now())
  resolvedAt     DateTime?

  // Relations
  roomId         String
  room           Room     @relation(fields: [roomId], references: [id])
  
  reporterId     String
  reporter       User     @relation("Reporter", fields: [reporterId], references: [id])

  assigneeId     String?
  assignee       User?    @relation("Assignee", fields: [assigneeId], references: [id])

  scheduledDate  String?
  scheduledSlot  String?
  
  repairNotes    String?
  repairImage    String? // Store base64 or URL
  rating         Int?
  feedback       String?
}

model TechnicianAvailability {
  id           String   @id @default(cuid())
  staffId      String   @unique
  staff        User     @relation(fields: [staffId], references: [id])
  workingDays  String   // JSON array: ["Mon","Tue","Wed","Thu","Fri"]
  updatedAt    DateTime @updatedAt
}

model TechnicianBlockedSlot {
  id       String @id @default(cuid())
  staffId  String
  staff    User   @relation(fields: [staffId], references: [id])
  date     String // "YYYY-MM-DD"
  type     String // "Full Day" | "Morning" | "Afternoon"
  reason   String?

  @@index([staffId, date])
}

model TenantDocument {
  id        String   @id @default(cuid())
  name      String
  type      String
  size      Int
  fileData  String   // Store base64
  createdAt DateTime @default(now())

  tenantId  String
  tenant    User     @relation(fields: [tenantId], references: [id])
}
